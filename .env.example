# ============================================================================
# Wayco Intake — environment configuration
# Copy to `.env.local` and fill in. Everything is OPTIONAL: with nothing set the
# app runs in MOCK/TEST mode so you can develop and QA without external accounts.
# ============================================================================

# ---- SurveyMonkey: embedded survey (client-visible) ----
# The web-link / embed URL of your SurveyMonkey intake survey, e.g.
# https://www.surveymonkey.com/r/XXXXXXX  — shown in an iframe on /intake.
# When empty, /intake renders a styled setup placeholder instead of the survey.
NEXT_PUBLIC_SM_SURVEY_URL=

# RECOMMENDED embed: SurveyMonkey's "Website" collector JS embed script URL, e.g.
# https://widget.surveymonkey.com/collect/website/js/XXXXXXX.js  (SurveyMonkey ->
# Collect Responses -> Website -> copy the script src). Avoids iframe X-Frame
# blocking. Takes precedence over NEXT_PUBLIC_SM_SURVEY_URL when both are set.
NEXT_PUBLIC_SM_EMBED_SRC=

# ---- SurveyMonkey: webhook -> response enrichment (server-only) ----
# Access token for a SurveyMonkey private app (Settings -> API). Used to fetch
# full response details when a webhook fires (the webhook only carries IDs).
SURVEYMONKEY_ACCESS_TOKEN=
# Shared secret used to HMAC-verify incoming webhooks. When empty, signature
# verification is skipped (logged). Must match your SurveyMonkey app config.
SURVEYMONKEY_WEBHOOK_SECRET=
# SurveyMonkey API base (override only for testing/mocks).
SURVEYMONKEY_API_BASE=https://api.surveymonkey.com/v3
# JSON map of canonical field -> SurveyMonkey question id, e.g.
# {"firstName":"q_first","email":"q_email","incidentType":"q_type"}
# When empty, the normalizer flattens all answers into raw + heuristically
# detects email/phone, and flags the lead `mapping_incomplete`.
SURVEYMONKEY_QUESTION_MAP=

# Allow inline test payloads (body.details) to the webhook in NON-production.
# Never honored when NODE_ENV=production.
SM_ALLOW_TEST_PAYLOADS=true

# ---- Wayco intake platform: lead delivery (server-only) ----
# Endpoint that receives the normalized lead JSON for the call team.
# When empty, forwarding runs in mock mode (logged, lead still persisted).
WAYCO_INTAKE_URL=
WAYCO_API_KEY=

# ---- /leads call-team view (server-only) ----
# Shared token gating the /leads page. Visit /leads?token=THIS_VALUE.
# When empty, /leads is DISABLED in production and read-only-open in dev.
LEADS_ACCESS_TOKEN=
